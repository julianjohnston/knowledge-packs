# ── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret

# ── Deepgram ────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://voice_user:voice_pass@localhost:5432/voice_db

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Webhook ─────────────────────────────────────────────────────────────────
# Public URL where Twilio can reach your server (use ngrok for local dev)
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io

# ── Storage ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=your-voice-recordings-bucket

# ── Notifications ───────────────────────────────────────────────────────────
# Internal webhook to fire in-app notifications
INAPP_NOTIFICATION_URL=http://localhost:4000/internal/notifications

# SMTP for email notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=AIMS-OS Voice <no-reply@your-domain.com>

# ── Agent Engine ────────────────────────────────────────────────────────────
# Internal endpoint for your AI agent engine
AGENT_ENGINE_URL=http://localhost:4001

# ── Security ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed workspace IDs (leave empty to allow all)
ALLOWED_WORKSPACE_IDS=
