{
  "name": "@aims-os/voice-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "AIMS-OS Voice Channel Gateway — real-time STT/TTS/WebSocket service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node -e \"require('./dist/db/migrate.js').migrate()\"",
    "migrate:dev": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.3.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/websocket": "^10.0.1",
    "aws-sdk": "^2.1590.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "openai": "^4.47.0",
    "pg": "^8.12.0",
    "twilio": "^5.2.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
